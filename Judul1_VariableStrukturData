def menu():
    print("1. Tampilkan address list skor")
    print("2. Tampilkan address skor tiap ronde")
    print("3. Masukkan skor untuk setiap ronde")
    print("4. Cari skor suatu ronde")
    print("5. Ubah skor suatu ronde")
    print("6. Keluar")


def main():
    a = [0] * 5
    running = True
    while running:
        menu()
        try:
            choice = int(input("Pilihan: "))
        except ValueError:
            print("Masukkan angka yang valid!")
            continue

        if choice == 1:
            print(f"Address list skor: {id(a)}")

        elif choice == 2:
            for i in range(5):
                print(f"Address ronde {i+1}: {id(a[i])}")

        elif choice == 3:
            print("Masukkan skor untuk 5 ronde:")
            for i in range(5):
                while True:
                    try:
                        a[i] = int(input(f"Skor ronde {i+1} = "))
                        break
                    except ValueError:
                        print("Input tidak valid!")
            print(f"Skor sekarang: {a}")

        elif choice == 4:
            try:
                r = int(input("Masukkan ronde (1-5): "))
                if 1 <= r <= 5:
                    print(f"Skor ronde {r} = {a[r-1]}")
                else:
                    print("Ronde tidak valid!")
            except:
                print("Input tidak valid!")

        elif choice == 5:
            try:
                r = int(input("Masukkan ronde yang ingin diubah (1-5): "))
                if 1 <= r <= 5:
                    nilai = int(input("Masukkan skor baru: "))
                    a[r-1] = nilai
                    print(f"Skor sekarang: {a}")
                else:
                    print("Ronde tidak valid!")
            except:
                print("Input tidak valid!")

        elif choice == 6:
            running = False
            print("Program selesai.")

        else:
            print("Pilihan tidak valid!")


if __name__ == "__main__":
    main()
